@model CinemaApp.Models.Genre
@{
    ViewData["Title"] = "Add New Genre";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="section-header">
                <div class="section-label">Admin</div>
                <h1 class="section-title">ADD NEW GENRE</h1>
            </div>
            <div class="bg-dark-card rounded-custom p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label asp-for="Name" class="form-label"></label>
                        <input asp-for="Name" class="form-control" placeholder="e.g., Action, Drama..." />
                        <span asp-validation-for="Name" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Icon" class="form-label"></label>
                        <input asp-for="Icon" class="form-control" placeholder="e.g., 💥 🎭 😂" />
                    </div>
                    <div class="mb-4">
                        <label asp-for="Description" class="form-label"></label>
                        <textarea asp-for="Description" class="form-control" rows="2"></textarea>
                    </div>
                    <div class="d-flex gap-3">
                        <button type="submit" class="btn btn-accent px-4">
                            <i class="bi bi-plus-lg me-2"></i>Add
                        </button>
                        <a asp-controller="Genres" asp-action="Index" class="btn btn-outline-light px-4">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>