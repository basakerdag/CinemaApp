@model CinemaApp.Models.Movie
@{
    ViewData["Title"] = "Add New Movie";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="section-header">
                <div class="section-label">Admin Panel</div>
                <h1 class="section-title">ADD NEW MOVIE</h1>
            </div>

            <div class="bg-dark-card rounded-custom p-4">
                <form asp-action="Create" method="post">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-8">
                            <label asp-for="Title" class="form-label"></label>
                            <input asp-for="Title" class="form-control" />
                            <span asp-validation-for="Title" class="text-danger small"></span>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Year" class="form-label"></label>
                            <input asp-for="Year" class="form-control" type="number" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="GenreId" class="form-label">Genre</label>
                            <select asp-for="GenreId" asp-items="ViewBag.Genres" class="form-select">
                                <option value="">Select Genre</option>
                            </select>
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Director" class="form-label"></label>
                            <input asp-for="Director" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Description" class="form-label"></label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                        <div class="col-12">
                            <label asp-for="Cast" class="form-label"></label>
                            <input asp-for="Cast" class="form-control" placeholder="Separate with commas: Actor 1, Actor 2" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="ImdbRating" class="form-label"></label>
                            <input asp-for="ImdbRating" class="form-control" type="number" step="0.1" min="0" max="10" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Duration" class="form-label"></label>
                            <input asp-for="Duration" class="form-control" type="number" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Language" class="form-label"></label>
                            <input asp-for="Language" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Country" class="form-label"></label>
                            <input asp-for="Country" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="PosterUrl" class="form-label"></label>
                            <input asp-for="PosterUrl" id="PosterUrl" class="form-control" placeholder="https://..." />
                            <img id="posterPreview" src="" alt="Poster" class="mt-2 rounded-3" style="max-width:120px;display:none">
                        </div>
                        <div class="col-12">
                            <label asp-for="TrailerUrl" class="form-label"></label>
                            <input asp-for="TrailerUrl" class="form-control" placeholder="YouTube or other URL" />
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="IsFeatured" class="form-check-input" type="checkbox" style="accent-color:var(--accent)" />
                                <label asp-for="IsFeatured" class="form-check-label text-muted">Feature on homepage</label>
                            </div>
                        </div>
                        <div class="col-12 d-flex gap-3 pt-2">
                            <button type="submit" class="btn btn-accent px-4">
                                <i class="bi bi-plus-lg me-2"></i>Add Movie
                            </button>
                            <a asp-action="Index" class="btn btn-outline-light px-4">Cancel</a>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>