@{
    ViewData["Title"] = "Admin Panel";
    var movies = ViewBag.Movies as List<CinemaApp.Models.Movie> ?? new();
    var genres = ViewBag.Genres as List<CinemaApp.Models.Genre> ?? new();
    var users = ViewBag.Users as List<CinemaApp.Models.AppUser> ?? new();
    var reviews = ViewBag.Reviews as List<CinemaApp.Models.Review> ?? new();
}

<div class="container py-5">
    <div class="section-header">
        <div class="section-label">Management Panel</div>
        <h1 class="section-title">ADMIN PANEL</h1>
    </div>

    <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon">🎬</div>
                <div>
                    <div class="stat-card-num">@ViewBag.TotalMovies</div>
                    <div class="text-muted small">Movies</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon">🎭</div>
                <div>
                    <div class="stat-card-num">@ViewBag.TotalGenres</div>
                    <div class="text-muted small">Genres</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon">👥</div>
                <div>
                    <div class="stat-card-num">@ViewBag.TotalUsers</div>
                    <div class="text-muted small">Users</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="stat-card">
                <div class="stat-card-icon">💬</div>
                <div>
                    <div class="stat-card-num">@ViewBag.TotalReviews</div>
                    <div class="text-muted small">Reviews</div>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-3 mb-4 flex-wrap">
        <a asp-controller="Movies" asp-action="Create" class="btn btn-accent">
            <i class="bi bi-plus-lg me-2"></i>Add Movie
        </a>
        <a asp-controller="Genres" asp-action="Create" class="btn btn-outline-light">
            <i class="bi bi-plus-lg me-2"></i>Add Genre
        </a>
    </div>

    <div class="row g-4">
        <div class="col-md-2">
            <div class="admin-sidebar">
                <button class="admin-menu-item active" data-tab="movies">
                    <i class="bi bi-film"></i> Movies
                </button>
                <button class="admin-menu-item" data-tab="genres">
                    <i class="bi bi-grid"></i> Genres
                </button>
                <button class="admin-menu-item" data-tab="users">
                    <i class="bi bi-people"></i> Users
                </button>
                <button class="admin-menu-item" data-tab="reviews">
                    <i class="bi bi-chat-dots"></i> Reviews
                </button>
            </div>
        </div>

        <div class="col-md-10">
            <div class="admin-tab-panel" data-panel="movies">
                <div class="bg-dark-card rounded-custom p-0 overflow-hidden">
                    <div class="px-4 py-3" style="border-bottom:1px solid var(--border)">
                        <h5 class="font-bebas mb-0" style="letter-spacing:1px">MOVIES (@movies.Count)</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-dark-custom mb-0">
                            <thead>
                                <tr>
                                    <th>Movie</th>
                                    <th>Genre</th>
                                    <th>Year</th>
                                    <th>IMDB</th>
                                    <th>Featured</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var m in movies)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center gap-3">
                                                @if (!string.IsNullOrEmpty(m.PosterUrl))
                                                {
                                                    <img src="@m.PosterUrl" alt="" class="rounded-2" style="width:36px;height:52px;object-fit:cover">
                                                }
                                                <span class="fw-600">@m.Title</span>
                                            </div>
                                        </td>
                                        <td><span class="meta-badge text-muted" style="font-size:.75rem">@m.Genre?.Name</span></td>
                                        <td class="text-muted">@m.Year</td>
                                        <td class="text-gold">@(m.ImdbRating?.ToString("F1") ?? "-")</td>
                                        <td>
                                            @if (m.IsFeatured)
                                            {
                                                <span class="badge" style="background:var(--accent);font-size:.7rem">✓ Yes</span>
                                            }
                                        </td>
                                        <td>
                                            <div class="d-flex gap-2">
                                                <a asp-controller="Movies" asp-action="Details" asp-route-id="@m.Id" class="btn btn-sm btn-outline-secondary px-2 py-1">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                                <a asp-controller="Movies" asp-action="Edit" asp-route-id="@m.Id" class="btn btn-sm btn-outline-warning px-2 py-1">
                                                    <i class="bi bi-pencil"></i>
                                                </a>
                                                <form asp-controller="Movies" asp-action="Delete" asp-route-id="@m.Id" method="post"
                                                      onsubmit="return confirm('Are you sure you want to delete this movie?')">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="admin-tab-panel" data-panel="genres" style="display:none">
                <div class="bg-dark-card rounded-custom p-0 overflow-hidden">
                    <div class="px-4 py-3" style="border-bottom:1px solid var(--border)">
                        <h5 class="font-bebas mb-0" style="letter-spacing:1px">GENRES (@genres.Count)</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-dark-custom mb-0">
                            <thead><tr><th>Icon</th><th>Genre Name</th><th>Movie Count</th><th>Action</th></tr></thead>
                            <tbody>
                                @foreach (var g in genres)
                                {
                                    <tr>
                                        <td style="font-size:1.3rem">@g.Icon</td>
                                        <td class="fw-600">@g.Name</td>
                                        <td class="text-muted">@g.Movies.Count</td>
                                        <td>
                                            <form asp-controller="Genres" asp-action="Delete" asp-route-id="@g.Id" method="post"
                                                  onsubmit="return confirm('Are you sure you want to delete this genre?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1" @(g.Movies.Count > 0 ? "disabled" : "")>
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="admin-tab-panel" data-panel="users" style="display:none">
                <div class="bg-dark-card rounded-custom p-0 overflow-hidden">
                    <div class="px-4 py-3" style="border-bottom:1px solid var(--border)">
                        <h5 class="font-bebas mb-0" style="letter-spacing:1px">USERS (@users.Count)</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-dark-custom mb-0">
                            <thead><tr><th>Username</th><th>Email</th><th>Role</th><th>Registration Date</th></tr></thead>
                            <tbody>
                                @foreach (var u in users)
                                {
                                    <tr>
                                        <td class="fw-600">@u.Username</td>
                                        <td class="text-muted">@u.Email</td>
                                        <td>
                                            @if (u.IsAdmin)
                                            {
                                                <span class="badge" style="background:var(--accent-gold);color:#000;font-size:.7rem">Admin</span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary" style="font-size:.7rem">User</span>
                                            }
                                        </td>
                                        <td class="text-muted">@u.CreatedAt.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <div class="admin-tab-panel" data-panel="reviews" style="display:none">
                <div class="bg-dark-card rounded-custom p-0 overflow-hidden">
                    <div class="px-4 py-3" style="border-bottom:1px solid var(--border)">
                        <h5 class="font-bebas mb-0" style="letter-spacing:1px">REVIEWS (@reviews.Count)</h5>
                    </div>
                    <div class="table-responsive">
                        <table class="table table-dark-custom mb-0">
                            <thead><tr><th>Movie</th><th>User</th><th>Rating</th><th>Review</th><th>Date</th><th>Action</th></tr></thead>
                            <tbody>
                                @foreach (var r in reviews)
                                {
                                    <tr>
                                        <td class="fw-600 text-accent">@r.Movie?.Title</td>
                                        <td class="text-muted">@r.ReviewerName</td>
                                        <td class="text-gold">@r.Rating/10</td>
                                        <td class="text-muted" style="max-width:200px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap">@r.Content</td>
                                        <td class="text-muted">@r.CreatedAt.ToString("dd.MM.yyyy")</td>
                                        <td>
                                            <form asp-controller="Admin" asp-action="DeleteReview" asp-route-id="@r.Id" method="post"
                                                  onsubmit="return confirm('Are you sure you want to delete this review?')">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-sm btn-outline-danger px-2 py-1">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>