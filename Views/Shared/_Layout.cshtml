<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — CinemaApp</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>

<nav class="navbar navbar-expand-lg navbar-dark sticky-top" id="mainNav">
    <div class="container">
        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
            <span class="brand-icon">🎬</span>
            <span class="brand-text">CINEMA<span class="brand-accent">APP</span></span>
        </a>
        <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
            <i class="bi bi-list fs-4"></i>
        </button>
        <div class="collapse navbar-collapse" id="navMenu">
            <ul class="navbar-nav me-auto gap-1">
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                        <i class="bi bi-house"></i> Home
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Movies" asp-action="Index">
                        <i class="bi bi-film"></i> Movies
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Genres" asp-action="Index">
                        <i class="bi bi-grid-3x3-gap"></i> Genres
                    </a>
                </li>
                <li class="nav-item">
                    <a class="nav-link" asp-controller="Home" asp-action="About">
                        <i class="bi bi-info-circle"></i> About
                    </a>
                </li>
                @if (Context.Session.GetString("Username") != null)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Favorites" asp-action="Index">
                            <i class="bi bi-heart"></i> Favorites
                        </a>
                    </li>
                }
            </ul>
            <div class="navbar-nav gap-2 align-items-center">
                <!-- Search -->
                <form class="d-flex" asp-controller="Movies" asp-action="Index" method="get">
                    <div class="search-bar">
                        <i class="bi bi-search"></i>
                        <input class="form-control" type="search" name="search" placeholder="Search movies..." />
                    </div>
                </form>

                @if (Context.Session.GetString("Username") != null)
                {
                    <span class="text-accent fw-600">
                        <i class="bi bi-person-circle"></i> @Context.Session.GetString("Username")
                    </span>
                    @if (Context.Session.GetString("IsAdmin") == "true")
                    {
                        <a class="btn btn-sm btn-warning" asp-controller="Admin" asp-action="Index">
                            <i class="bi bi-shield-lock"></i> Admin
                        </a>
                    }
                    <a class="btn btn-sm btn-outline-light" asp-controller="Account" asp-action="Logout">Logout</a>
                }
                else
                {
                    <a class="btn btn-sm btn-outline-light" asp-controller="Account" asp-action="Login">Login</a>
                    <a class="btn btn-sm btn-accent" asp-controller="Account" asp-action="Register">Register</a>
                }
            </div>
        </div>
    </div>
</nav>

<main>
    @if (TempData["Success"] != null)
    {
        <div class="container mt-3">
            <div class="alert alert-success alert-dismissible fade show border-0 rounded-3" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        </div>
    }
    @RenderBody()
</main>

<footer class="site-footer mt-5">
    <div class="container">
        <div class="row gy-4">
            <div class="col-md-4">
                <div class="footer-brand">🎬 CinemaApp</div>
                <p class="text-muted small mt-2">Discover, rate, and collect the best movies.</p>
            </div>
            <div class="col-md-4">
                <h6 class="text-light mb-3">Quick Links</h6>
                <ul class="list-unstyled footer-links">
                    <li><a asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a asp-controller="Movies" asp-action="Index">All Movies</a></li>
                    <li><a asp-controller="Genres" asp-action="Index">Movie Genres</a></li>
                </ul>
            </div>
          
        </div>
        <hr class="border-secondary my-3">
        <p class="text-center text-muted small mb-0">© @DateTime.Now.Year CinemaApp </p>
    </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
