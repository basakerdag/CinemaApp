@{
    ViewData["Title"] = "About";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-9">

            <!-- Hero -->
            <div class="text-center mb-5">
                <div style="font-size:4rem">🎬</div>
                <h1 class="font-bebas mt-3" style="font-size:3rem;letter-spacing:3px;color:var(--accent)">About CinemaApp</h1>
                <!-- text-muted yerine text-white-50 veya text-light kullanabilirsiniz -->
                <p class="text-light mt-2" style="font-size:1.1rem;max-width:560px;margin:0 auto">
                    A cinema platform designed for movie lovers — making it easy to discover, rate, and share your passion for film.
                </p>
            </div>

            <!-- Mission -->
            <div class="bg-dark-card rounded-custom p-5 mb-4">
                <div class="d-flex align-items-start gap-4">
                    <span style="font-size:2.5rem;line-height:1">🍿</span>
                    <div>
                        <h4 class="font-bebas text-accent mb-2" style="letter-spacing:1px;font-size:1.4rem">WHAT WE OFFER</h4>
                        <!-- Using text-white for readability on dark background -->
                        <p class="text-white mb-0" style="line-height:1.8">
                            CinemaApp is your go-to destination for exploring thousands of movies, tracking IMDB ratings, filtering by genre,
                            and sharing your thoughts with a community of fellow film enthusiasts. Whether you're hunting for your next watch
                            or want to review what you've already seen — CinemaApp has you covered.
                        </p>
                    </div>
                </div>
            </div>

            <!-- Feature Cards -->
            <div class="row g-4 mb-4">
                @foreach (var item in new[] {
                    ("🔍", "Smart Search", "Find any movie in seconds by title or director. Exactly what you're looking for, instantly."),
                    ("🎯", "Advanced Filtering", "Filter by genre and release year to narrow down your perfect watch."),
                    ("⭐", "IMDB Ratings", "Sort movies by IMDB scores and start with the best of the best."),
                    ("💬", "Reviews & Ratings", "Rate films yourself, leave reviews, and read what others think."),
                    ("📱", "Works on Any Device", "Seamless experience on phone, tablet, or desktop. Watch from anywhere."),
                    ("📄", "Easy Browsing", "Navigate thousands of titles comfortably with clean, paginated listings.")
                })
                {
                    <div class="col-md-6">
                        <div class="bg-dark-card rounded-custom p-4 h-100" style="border:1px solid var(--border);transition:border-color .2s"
                             onmouseover="this.style.borderColor='var(--accent)'" onmouseout="this.style.borderColor='var(--border)'">
                            <div class="d-flex align-items-center gap-3 mb-2">
                                <span style="font-size:1.6rem">@item.Item1</span>
                                <h6 class="font-bebas text-accent mb-0" style="letter-spacing:1px;font-size:1rem">@item.Item2</h6>
                            </div>
                            <!-- Using text-white for readability on dark background -->
                            <p class="text-white mb-0" style="font-size:.88rem;line-height:1.7">@item.Item3</p>
                        </div>
                    </div>
                }
            </div>

            <!-- How it works -->
            <div class="bg-dark-card rounded-custom p-5 mb-4">
                <h4 class="font-bebas text-accent mb-4 text-center" style="letter-spacing:1px;font-size:1.4rem">🚀 HOW IT WORKS</h4>
                <div class="row g-0">
                    @{
                        var steps = new[] {
                            ("1", "Sign Up", "Create your free account and join the community."),
                            ("2", "Discover Movies", "Search and filter to find films tailored to your taste."),
                            ("3", "Rate & Review", "Share your thoughts and rate what you've watched."),
                            ("4", "Explore More", "Discover recommendations from other users.")
                        };
                        for (int i = 0; i < steps.Length; i++) {
                            var s = steps[i];
                            <div class="col-md-3 text-center px-3 @(i < steps.Length - 1 ? "border-end-custom" : "")">
                                <div class="rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                                     style="width:48px;height:48px;background:var(--accent);font-weight:700;font-size:1.1rem;color:#000">
                                    @s.Item1
                                </div>
                                <div class="fw-600 text-light mb-1" style="font-size:.9rem">@s.Item2</div>
                                <!-- Using text-white for readability on dark background -->
                                <div class="text-white" style="font-size:.8rem">@s.Item3</div>
                            </div>
                        }
                    }
                </div>
            </div>

            <!-- CTA -->
            <div class="text-center">
                <!-- Using text-light for description text above buttons -->
                <p class="text-light mb-3">Still waiting? Thousands of movies are ready for you.</p>
                <a asp-controller="Movies" asp-action="Index" class="btn btn-accent px-5 py-2 me-2">
                    <i class="bi bi-play-fill me-2"></i>Explore Movies
                </a>
                <a asp-controller="Account" asp-action="Register" class="btn btn-outline-secondary px-5 py-2">
                    <i class="bi bi-person-plus me-2"></i>Sign Up
                </a>
            </div>

        </div>
    </div>
</div>