@{
    ViewData["Title"] = "Register";
    Layout = "_Layout";
}

<div class="auth-container">
    <div class="auth-card">
        <div class="text-center mb-4">
            <div style="font-size:2.5rem;margin-bottom:8px">🎬</div>
            <h1 class="auth-title">REGISTER</h1>
            <p class="text-muted small">Create a new account</p>
        </div>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger border-0 rounded-3 mb-4" style="background:rgba(220,53,69,0.15);color:#f08080">
                <i class="bi bi-exclamation-circle me-2"></i>@ViewBag.Error
            </div>
        }

        <form asp-action="Register" method="post">
            @Html.AntiForgeryToken()
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input type="text" name="username" class="form-control" placeholder="username" required autocomplete="username" />
            </div>
            <div class="mb-3">
                <label class="form-label">Email</label>
                <input type="email" name="email" class="form-control" placeholder="example@mail.com" required />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input type="password" name="password" class="form-control" placeholder="At least 6 characters" required minlength="6" autocomplete="new-password" />
            </div>
            <div class="mb-4">
                <label class="form-label">Confirm Password</label>
                <input type="password" name="confirmPassword" class="form-control" placeholder="Repeat your password" required autocomplete="new-password" />
            </div>
            <button type="submit" class="btn btn-accent w-100 py-2 fw-600">
                <i class="bi bi-person-plus me-2"></i>Register
            </button>
        </form>

        <div class="text-center mt-4">
            <span class="text-muted small">Already have an account?</span>
            <a asp-controller="Account" asp-action="Login" class="text-accent text-decoration-none small fw-600 ms-1">Login</a>
        </div>
    </div>
</div>
